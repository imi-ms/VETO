root = true

[*]
charset = utf-8
end_of_line = crlf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
tab_width = 4
trim_trailing_whitespace = true

[*.vue]
indent_size = 2
tab_width = 2

[{*.ats,*.cts,*.mts,*.ts}]
indent_size = 2
tab_width = 2

[{*.cjs,*.js}]
indent_size = 2
tab_width = 2

[*.md]
trim_trailing_whitespace = false

[data/example-CR.csv]
end_of_line = cr

[data/example-CRLF.csv]
end_of_line = crlf

[data/example-LF.csv]
end_of_line = lf
